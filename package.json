{
  "type": "module",
  "dependencies": {
    "@biomejs/biome": "^2.4.12",
    "@lezer/generator": "^1.8.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@tailwindcss/cli": "^4.2.2",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "codemirror": "^6.0.2",
    "concurrently": "^9.2.1",
    "cytoscape": "^3.33.2",
    "cytoscape-dagre": "^2.5.0",
    "esbuild": "^0.28.0"
  },
  "scripts": {
    "build:lezer": "lezer-generator src/lezer/forkjoin.grammar -o out/forkjoin/parser.js && lezer-generator src/lezer/parbeginparend.grammar -o out/parbeginparend/parser.js",
    "build:css": "tailwindcss -i src/index.css -o web/index.css",
    "build:js": "tsgo",
    "watch:js": "tsgo --watch",
    "watch:bundle": "bun build --watch --outfile=web/main.js --sourcemap=inline out/main.js",
    "watch:bundlees": "esbuild --watch --bundle --outfile=web/main.js --sourcemap=inline out/main.js",
    "watch": "concurrently  \"bun watch:js\" \"bun watch:bundlees\"",
    "bundle": "bun build --minify --outfile=web/main.js out/main.js",
    "lint": "biome check --write --unsafe biome.json package.json tsconfig.json src test",
    "test": "bun test",
    "build": "bun run build:css && bun run build:lezer && bun run build:js && bun run bundle"
  }
}
